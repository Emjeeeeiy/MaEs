rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is admin via Custom Claims
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Helper function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Billing feedback images: Restrict to user-specific folders
    match /billingFeedbackImages/{userId}/{fileName} {
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && request.resource.contentType.matches('image/.*');
      
      // Feedback is reviewed by admins or the user who uploaded it
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // Financial documents: Restrict to user-specific folders
    match /financialDocuments/{userId}/{fileName} {
      allow write: if isAuthenticated()
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
      
      // Financial documents are reviewed by admins or the user who uploaded it
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }
  }
}
