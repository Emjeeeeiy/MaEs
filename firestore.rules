rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin via Custom Claims
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Helper function to check ownership by email
    function isOwner(email) {
      return request.auth != null && (request.auth.token.email == email || isAdmin());
    }

    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      allow create: if request.auth != null 
                    && request.auth.uid == userId 
                    && request.resource.data.role == 'user'
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.status == 'active';
      
      allow update: if request.auth != null && (
        isAdmin() || 
        (request.auth.uid == userId 
         && request.resource.data.role == resource.data.role
         && request.resource.data.status == resource.data.status
         // Allow updating profile fields and rate limiting field
         && (request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lastAppointmentAt', 'username', 'email', 'completeName', 'age', 'birthday', 'cellphone', 'gender', 'address', 'profileImageBase64']) 
             || isAdmin()))
      );
      
      allow delete: if isAdmin();
    }

    // Invoices Collection
    match /invoices/{invoiceId} {
      allow read: if isOwner(resource.data.email);
      allow create, update, delete: if isAdmin();
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read: if isOwner(resource.data.email);
      allow create: if request.auth != null 
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // Appointments Collection
    match /appointments/{appointmentId} {
      allow read: if isOwner(resource.data.email);
      allow create: if request.auth != null 
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.status == 'Pending'
                    // Simple rate limit: 1 minute cooldown check against user doc
                    && (
                      !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
                      !('lastAppointmentAt' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
                      request.time > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.lastAppointmentAt + duration.value(1, 'm')
                    );
      allow update, delete: if isAdmin();
    }

    // Services Collection
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userEmail);
      allow create, update, delete: if isAdmin();
    }

    // Billing Feedback Collection
    match /billingFeedback/{feedbackId} {
      allow read: if isAdmin() || isOwner(resource.data.email);
      allow create: if request.auth != null && request.resource.data.email == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    // Financial Documents Collection
    match /financialDocuments/{docId} {
      allow read: if isAdmin() || isOwner(resource.data.email);
      allow create: if request.auth != null && request.resource.data.email == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    // Tawk Logs Collection
    match /tawkLogs/{logId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null; // Allow users to log support starts
    }
  }
}
